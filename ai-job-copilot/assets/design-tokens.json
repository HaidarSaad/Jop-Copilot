{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "source": "docs/brand-guidelines.md",
  "colors": {
    "light": {
      "primary": "#1E3A5F",
      "secondary": "#2563EB",
      "accent": "#059669",
      "background": "#F8FAFC",
      "foreground": "#0F172A",
      "card": "#FFFFFF",
      "card-border": "#E4E7EB",
      "muted": "#F1F3F5",
      "muted-fg": "#64748B",
      "destructive": "#DC2626",
      "ring": "#1E3A5F"
    },
    "dark": {
      "primary": "#3B82F6",
      "secondary": "#60A5FA",
      "accent": "#34D399",
      "background": "#0F172A",
      "foreground": "#F1F5F9",
      "card": "#1E293B",
      "card-border": "#334155",
      "muted": "#1E293B",
      "muted-fg": "#94A3B8",
      "destructive": "#EF4444",
      "ring": "#3B82F6"
    }
  },
  "gradients": {
    "primary": "linear-gradient(135deg, #1E3A5F 0%, #3B82F6 100%)",
    "accent": "linear-gradient(135deg, #059669 0%, #34D399 100%)",
    "hero": "linear-gradient(135deg, #1E3A5F 0%, #0F172A 100%)"
  },
  "typography": {
    "headings": "Space Grotesk",
    "body": "Inter",
    "code": "JetBrains Mono"
  },
  "spacing": {},
  "borderRadius": {
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.05)",
    "md": "0 4px 6px rgba(0,0,0,0.1)",
    "lg": "0 10px 15px rgba(0,0,0,0.1)",
    "xl": "0 20px 25px rgba(0,0,0,0.15)"
  }
}